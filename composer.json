{
    "name": "zencoparent/zencoparent",
    "description": "ZenCoParent - Production-ready PHP 8.2+ SaaS/Community co-parenting web application",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "firebase/php-jwt": "^6.10",
        "league/oauth2-google": "^4.0",
        "monolog/monolog": "^3.7",
        "php-di/php-di": "^7.0",
        "phpmailer/phpmailer": "^6.9",
        "predis/predis": "^2.3",
        "ramsey/uuid": "^4.7",
        "respect/validation": "^2.3",
        "slim/psr7": "^1.7",
        "slim/slim": "^4.14",
        "stripe/stripe-php": "^16.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "mockery/mockery": "^1.6",
        "guzzlehttp/guzzle": "^7.9"
    },
    "autoload": {
        "psr-4": {
            "ZenCoParent\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ZenCoParent\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": "php -S localhost:8080 -t public",
        "test": "phpunit"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        },
        "audit": {
            "ignore": ["PKSA-y2cr-5h3j-g3ys"],
            "block-insecure": false
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}

APP_ENV=testing
APP_MODE=community
APP_SECRET=test-app-secret-long-enough-for-testing-purposes
APP_URL=http://localhost
APP_DEBUG=false

DB_CONNECTION=sqlite
DB_FILE=:memory:

JWT_SECRET=test-jwt-secret-long-enough-for-hs256-algorithm-testing
JWT_EXPIRY=3600
JWT_REFRESH_EXPIRY=86400

CSRF_SECRET=test-csrf-secret

STORAGE_PATH=/tmp/zencoparent_test_storage
STORAGE_URL=http://localhost/storage

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0

MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=zencoparent
MINIO_REGION=us-east-1

RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=60

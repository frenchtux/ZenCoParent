APP_NAME=ZenCoParent
APP_ENV=production
APP_MODE=saas
APP_SECRET=change-me-to-a-long-random-secret-at-least-64-chars
APP_URL=http://localhost
APP_DEBUG=false

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=zencoparent
DB_USERNAME=zencoparent
DB_PASSWORD=secret

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0

MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=zencoparent
MINIO_REGION=us-east-1

# Community mode — local file storage (ignored in SaaS mode)
STORAGE_PATH=/var/www/html/storage
STORAGE_URL=http://localhost/storage

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost/auth/oauth/google/callback

JWT_SECRET=change-me-to-another-long-random-secret
JWT_EXPIRY=3600
JWT_REFRESH_EXPIRY=2592000

CSRF_SECRET=change-me-csrf-secret

RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# SaaS licensing — master key known only to the vendor.
# Used internally to derive activation keys from installation keys.
# REQUIRED in SaaS mode. Generate a long random secret and keep it out of version control.
LICENSE_MASTER_KEY=

# Stripe — payment processing (SaaS mode only)
# Keys available at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# One-time price ID for purchasing an installation key (create in Stripe Dashboard)
STRIPE_INSTALLATION_KEY_PRICE_ID=
